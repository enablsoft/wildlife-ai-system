# =============================================================================
# Wildlife AI — environment template (safe to commit)
# =============================================================================
# Quick smoke test (Windows): copy ".env.demo" to ".env" or run scripts/quick-demo.ps1
#
# FIRST TIME:
#   1. Copy this file to ".env" in the same folder as docker-compose.yml
#   2. Adjust image tags / ports if needed
#   3. Run: docker compose --env-file .env up -d
#
# Do NOT commit ".env" — it is listed in .gitignore. Only ".env.example" is
# tracked so everyone knows which variables exist.
#
# Image tags:
#   - "local" = you built images on this machine with matching names
#   - Otherwise use a tag published to GHCR, e.g.
#       ghcr.io/<your-org>/wildlife-ai-ml-service:v1.0.0
# =============================================================================

# --- Container images (GHCR or local) ---
ML_SERVICE_IMAGE=ghcr.io/enablsoft/wildlife-ai-ml-service:local
BATCH_UI_IMAGE=ghcr.io/enablsoft/wildlife-ai-batch-ui:local
SPECIES_SERVICE_IMAGE=ghcr.io/enablsoft/wildlife-ai-species-service:local

# --- Ports on your host (change if 8010 / 8090 / 8100 are already in use) ---
ML_SERVICE_PORT=8010
BATCH_UI_PORT=8090
SPECIES_SERVICE_PORT=8100

# --- Folders mounted into batch-ui (created on host if missing) ---
HOST_DATA_DIR=./data
HOST_MEDIA_DIR=./media
HOST_CONFIG_DIR=./config

# --- Local webapp logging (TimedRotatingFileHandler) ---
# LOG_ROTATE_WHEN supports values like: midnight, D, H, M
LOG_ROTATE_WHEN=midnight
# Rotate every N units of LOG_ROTATE_WHEN
LOG_ROTATE_INTERVAL=1
# Number of rotated log files to keep
LOG_BACKUP_DAYS=14

# --- Webapp database backend ---
# sqlite (default) or mongo
DB_BACKEND=sqlite
# Used when DB_BACKEND=mongo
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=wildlife_webapp
# Optional test override for backend smoke tests (falls back to MONGO_URI)
MONGO_URI_TEST=mongodb://127.0.0.1:27017
